TABLER_LAYOUT_BOXED=1
TABLER_LAYOUT_NAVBAR_STICKY=0
TABLER_LAYOUT_NAVBAR_DARK=0
TABLER_LAYOUT_SIDEBAR_DARK=1
TABLER_LAYOUT="vertical"
TABLER_HEADER_BG=#514d4d
TABLER_SIDEBAR_BG="rgba(214, 57, 57, 1)"
TABLER_CARD_STYLE="flat"
TABLER_HEADER_MENU_BG=#e0e0e0
TABLER_HEADER_STICKY="false"

TABLER_THEME_BG="rgba(214, 57, 57, 1)"
TABLER_HEADER_TOP_BG="rgba(214, 57, 57, 1)"
TABLER_CONTAINER_WIDTH="standard"
TABLER_BOXED_BG="rgba(214, 57, 57, 1)"
TABLER_HEADER_OVERLAP_BG="rgba(214, 57, 57, 1)"
AUTH_LAYOUT="cover"
AUTH_FORM_POSITION="right"
THEME_CUSTOMIZATION_ENABLED=true
