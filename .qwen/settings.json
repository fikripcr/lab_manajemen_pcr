{
  "mcpServers": {
    "toon": {
      "command": "npx",
      "args": [
        "tsx",
        "/home/fmi/toon-mcp/index.ts"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "env": {
        "CONTEXT7_API_KEY": "ctx7sk-acdc6599-6b93-4908-a896-3f0eac9efd49"
      }
    },
    "filesystem": {
      "command": "wsl.exe",
      "args": [
        "bash",
        "-lc",
        "npx -y @modelcontextprotocol/server-filesystem /home/fmi/docker-apps/9028-laravel-boilerplate"
      ]
    },
    "laravel-boost": {
      "command": "bash",
      "args": [
        "-c",
        "docker exec -i laravel-boilerplate-app php artisan boost:mcp"
      ]
    }
  },
  "$version": 3,
  "permissions": {
    "allow": [
      "Bash(php *)",
      "Bash(docker exec *)",
      "Bash(npm run *)",
      "Bash(docker-compose *)"
    ]
  }
}